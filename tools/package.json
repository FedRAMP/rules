{
  "name": "tools",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "bun run --silent typecheck && bun run --silent test",
    "test": "bun run --silent test.ts",
    "typecheck": "tsc --noEmit",
    "fix": "bun run fix.ts",
    "build": "bun run --silent summary:rules",
    "summary": "bun run summary.ts",
    "test:fix": "bun test tests/fix.test.ts",
    "test:formatting": "bun test tests/formatting.test.ts",
    "test:schema": "bun test tests/schema.test.ts",
    "test:schema-validation": "bun test tests/schema-validation.test.ts",
    "test:ids": "bun test tests/id-alignment.test.ts",
    "test:keywords": "bun test tests/primary-keywords.test.ts",
    "test:terms": "bun test tests/terms.test.ts",
    "test:order": "bun test tests/property-order.test.ts",
    "test:summary": "bun test tests/summary.test.ts",
    "test:consistency": "bun test tests/zz-consistency-report.test.ts",
    "fix:terms": "bun run fix -- --scope terms",
    "fix:ids": "bun run fix -- --scope ids",
    "fix:order": "bun run fix -- --scope order",
    "fix:related": "bun run fix -- --scope related",
    "fix:display-names": "bun run fix -- --scope display-names",
    "summary:rules": "bun run summary -- --scope rules",
    "hooks:install": "sh ./install-git-hooks.sh",
    "export": "bun run export-spreadsheet.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
