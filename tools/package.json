{
  "name": "tools",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun test",
    "test:schema": "bun run validate-schema.ts",
    "test:ids": "bun run validate-item-ids.ts",
    "test:keywords": "bun run verify-primary-key-word.ts",
    "test:terms": "bun run update-frr-terms.ts",
    "validate": "bun run test:schema && bun run test:ids && bun run test:keywords && bun run test:terms",
    "terms:update": "bun run update-frr-terms.ts --write",
    "ids:fix": "bun run validate-item-ids.ts --in-place"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
