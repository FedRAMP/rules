{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fedramp.gov/schema/documentation.json",
  "title": "FedRAMP Consolidated Rules Schema",
  "type": "object",
  "required": ["info", "FRD", "FRR", "KSI"],
  "properties": {
    "info": {
      "type": "object",
      "required": ["title", "description", "version", "last_updated"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "last_updated": { "type": "string", "format": "date" },
        "default_artifacts": { "$ref": "#/$defs/default_artifacts" }
      },
      "additionalProperties": false
    },
    "FRD": {
      "type": "object",
      "required": ["info", "data"],
      "properties": {
        "info": { "$ref": "#/$defs/frd_document_info" },
        "data": { "$ref": "#/$defs/data_container_frd" }
      },
      "additionalProperties": false
    },
    "FRR": {
      "type": "object",
      "patternProperties": {
        "^[A-Z]{3}$": {
          "type": "object",
          "required": ["info", "data"],
          "properties": {
            "info": { "$ref": "#/$defs/frr_document_info" },
            "data": { "$ref": "#/$defs/data_container_frr" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "KSI": {
      "type": "object",
      "patternProperties": {
        "^[A-Z]{3}$": {
          "type": "object",
          "required": [
            "id",
            "name",
            "web_name",
            "short_name",
            "status",
            "indicators"
          ],
          "properties": {
            "id": { "type": "string", "pattern": "^KSI-[A-Z]{3}$" },
            "name": { "type": "string" },
            "web_name": { "type": "string" },
            "short_name": { "type": "string", "pattern": "^[A-Z]{3}$" },
            "status": { "$ref": "#/$defs/document_status" },
            "indicators": {
              "type": "object",
              "patternProperties": {
                "^KSI-[A-Z]{3}-[A-Z0-9]{3}$": {
                  "$ref": "#/$defs/ksi_indicator"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "frd_document_info": {
      "type": "object",
      "required": ["name", "short_name", "web_name", "purpose", "status"],
      "properties": {
        "name": { "type": "string" },
        "short_name": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "web_name": { "type": "string" },
        "purpose": { "type": "string" },
        "status": { "$ref": "#/$defs/document_status" },
        "effective": { "$ref": "#/$defs/effective_entry" },
        "20x": { "$ref": "#/$defs/frd_document_info_certification" },
        "rev5": { "$ref": "#/$defs/frd_document_info_certification" }
      },
      "allOf": [{ "$ref": "#/$defs/document_info_effective_rules" }],
      "additionalProperties": false
    },
    "frd_document_info_certification": {
      "type": "object",
      "properties": {
        "effective": { "$ref": "#/$defs/effective_entry" }
      },
      "additionalProperties": false
    },
    "frr_document_info": {
      "type": "object",
      "required": ["name", "short_name", "web_name", "purpose", "status"],
      "properties": {
        "name": { "type": "string" },
        "short_name": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "web_name": { "type": "string" },
        "purpose": { "type": "string" },
        "status": { "$ref": "#/$defs/document_status" },
        "effective": { "$ref": "#/$defs/effective_entry" },
        "labels": { "$ref": "#/$defs/frr_info_labels" },
        "flows": { "$ref": "#/$defs/info_flows" },
        "20x": { "$ref": "#/$defs/frr_document_info_certification" },
        "rev5": { "$ref": "#/$defs/frr_document_info_certification" }
      },
      "allOf": [{ "$ref": "#/$defs/document_info_effective_rules" }],
      "additionalProperties": false
    },
    "frr_document_info_certification": {
      "type": "object",
      "properties": {
        "effective": { "$ref": "#/$defs/effective_entry" },
        "labels": { "$ref": "#/$defs/frr_info_labels" },
        "flows": { "$ref": "#/$defs/info_flows" }
      },
      "additionalProperties": false
    },
    "document_status": {
      "type": "string",
      "enum": ["stable", "placeholder", "empty"]
    },
    "frr_data_label_name": {
      "enum": [
        "FRP",
        "AGC",
        "CSO",
        "CSF",
        "CSX",
        "CSL",
        "IAF",
        "IAS",
        "IAX",
        "IAL",
        "AGM",
        "ADP",
        "BST",
        "CAS",
        "ENH",
        "EVA",
        "OCR",
        "PRE",
        "QTR",
        "RPT",
        "RTR",
        "TFR",
        "TRC",
        "TRF",
        "UTC",
        "CLA",
        "APP",
        "APS",
        "USE",
        "SPN"
      ]
    },
    "frr_info_label_name": {
      "anyOf": [{ "$ref": "#/$defs/frr_data_label_name" }]
    },
    "frr_label_definition": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "frr_info_labels": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/frr_info_label_name" },
      "additionalProperties": { "$ref": "#/$defs/frr_label_definition" }
    },
    "info_flows": {
      "type": "array"
    },
    "document_info_effective_rules": {
      "type": "object",
      "anyOf": [
        {
          "properties": {
            "effective": true
          },
          "required": ["effective"]
        },
        {
          "properties": {
            "20x": {
              "type": "object",
              "properties": {
                "effective": true
              },
              "required": ["effective"]
            },
            "rev5": {
              "type": "object",
              "properties": {
                "effective": true
              },
              "required": ["effective"]
            }
          },
          "required": ["20x", "rev5"]
        }
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "effective": true
            },
            "required": ["effective"]
          },
          "then": {
            "properties": {
              "20x": {
                "not": {
                  "type": "object",
                  "properties": {
                    "effective": true
                  },
                  "required": ["effective"]
                }
              },
              "rev5": {
                "not": {
                  "type": "object",
                  "properties": {
                    "effective": true
                  },
                  "required": ["effective"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "20x": {
                "type": "object",
                "properties": {
                  "effective": true
                },
                "required": ["effective"]
              }
            },
            "required": ["20x"]
          },
          "then": {
            "properties": {
              "rev5": {
                "type": "object",
                "properties": {
                  "effective": true
                },
                "required": ["effective"]
              }
            },
            "required": ["rev5"]
          }
        },
        {
          "if": {
            "properties": {
              "rev5": {
                "type": "object",
                "properties": {
                  "effective": true
                },
                "required": ["effective"]
              }
            },
            "required": ["rev5"]
          },
          "then": {
            "properties": {
              "20x": {
                "type": "object",
                "properties": {
                  "effective": true
                },
                "required": ["effective"]
              }
            },
            "required": ["20x"]
          }
        }
      ]
    },
    "effective_entry": {
      "type": "object",
      "required": ["is"],
      "properties": {
        "is": { "type": "string", "enum": ["required", "optional", "no"] },
        "current_status": { "type": "string" },
        "date": { "$ref": "#/$defs/effective_dates" },
        "comments": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "signup_url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "effective_dates": {
      "type": "object",
      "required": ["obtain", "maintain"],
      "properties": {
        "obtain": { "type": "string", "format": "date" },
        "maintain": { "type": "string", "format": "date" },
        "grace_ends": { "type": "string", "format": "date" },
        "grace_by_assessment_months": { "type": "number" }
      },
      "oneOf": [
        {
          "required": ["grace_ends"],
          "properties": {
            "grace_ends": {}
          }
        },
        {
          "required": ["grace_by_assessment_months"],
          "properties": {
            "grace_by_assessment_months": {}
          }
        }
      ],
      "additionalProperties": false
    },
    "data_container_frd": {
      "type": "object",
      "required": ["all"],
      "properties": {
        "all": { "$ref": "#/$defs/frd_definitions_map" },
        "20x": { "$ref": "#/$defs/frd_definitions_map" },
        "rev5": { "$ref": "#/$defs/frd_definitions_map" }
      },
      "additionalProperties": false
    },
    "frd_definitions_map": {
      "type": "object",
      "patternProperties": {
        "^FRD-[A-Z]{3}$": { "$ref": "#/$defs/frd_definition" }
      },
      "additionalProperties": false
    },
    "frd_definition": {
      "type": "object",
      "required": ["term", "definition", "alts", "updated"],
      "properties": {
        "term": { "type": "string" },
        "definition": { "type": "string" },
        "note": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "tag": { "type": "string" },
        "alts": { "type": "array", "items": { "type": "string" } },
        "do_not_link": { "type": "boolean" },
        "reference": { "type": "string" },
        "reference_url": { "type": "string", "format": "uri" },
        "referenceurl": { "type": "string", "format": "uri" },
        "updated": { "$ref": "#/$defs/updated_list" }
      },
      "additionalProperties": false
    },
    "data_container_frr": {
      "type": "object",
      "properties": {
        "all": { "$ref": "#/$defs/frr_requirements_map" },
        "20x": { "$ref": "#/$defs/frr_requirements_map" },
        "rev5": { "$ref": "#/$defs/frr_requirements_map" }
      },
      "additionalProperties": false
    },
    "frr_requirements_map": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/frr_data_label_name" },
      "additionalProperties": { "$ref": "#/$defs/frr_requirements_label_group" }
    },
    "frr_requirements_label_group": {
      "type": "object",
      "patternProperties": {
        "^[A-Z]{3}-[A-Z]{3}-[A-Z0-9]{3}$": {
          "$ref": "#/$defs/frr_requirement"
        }
      },
      "additionalProperties": false
    },
    "frr_requirement": {
      "type": "object",
      "required": ["name", "affects"],
      "oneOf": [
        {
          "properties": { "statement": {}, "primary_key_word": {} },
          "required": ["statement", "primary_key_word"],
          "not": {
            "properties": { "varies_by_class": {} },
            "required": ["varies_by_class"]
          }
        },
        {
          "properties": { "varies_by_class": {} },
          "required": ["varies_by_class"],
          "not": {
            "anyOf": [
              {
                "properties": { "statement": {} },
                "required": ["statement"]
              },
              {
                "properties": { "primary_key_word": {} },
                "required": ["primary_key_word"]
              }
            ]
          }
        }
      ],
      "properties": {
        "name": { "type": "string" },
        "statement": { "type": "string" },
        "varies_by_class": {
          "type": "object",
          "required": ["b", "c"],
          "properties": {
            "a": { "$ref": "#/$defs/frr_requirement_level" },
            "b": { "$ref": "#/$defs/frr_requirement_level" },
            "c": { "$ref": "#/$defs/frr_requirement_level" },
            "d": { "$ref": "#/$defs/frr_requirement_level" }
          },
          "additionalProperties": false
        },
        "following_information": {
          "type": "array",
          "items": { "type": "string" }
        },
        "following_information_bullets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "danger": { "type": "string" },
        "note": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "reference": { "type": "string" },
        "reference_url": { "type": "string", "format": "uri" },
        "reference_url_web_name": { "type": "string" },
        "effective_date": { "$ref": "#/$defs/effective_dates" },
        "corrective_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "primary_key_word": {
          "$ref": "#/$defs/primary_key_word_enum"
        },
        "affects": { "type": "array", "items": { "type": "string" } },
        "artifacts": { "$ref": "#/$defs/artifacts" },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "key_tests", "examples"],
            "properties": {
              "id": { "type": "string" },
              "key_tests": { "type": "array", "items": { "type": "string" } },
              "examples": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "timeframe_type": { "type": "string" },
        "timeframe_num": { "type": "number" },
        "notification": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["party", "method", "target"],
            "properties": {
              "party": { "type": "string" },
              "method": { "type": "string" },
              "target": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            },
            "additionalProperties": false
          }
        },
        "controls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "terms": { "type": "array", "items": { "type": "string" } },
        "updated": { "$ref": "#/$defs/updated_list" }
      },
      "additionalProperties": false
    },
    "frr_requirement_level": {
      "type": "object",
      "required": ["primary_key_word", "statement"],
      "properties": {
        "statement": { "type": "string" },
        "following_information": {
          "type": "array",
          "items": { "type": "string" }
        },
        "primary_key_word": { "$ref": "#/$defs/primary_key_word_enum" },
        "effective_date": { "$ref": "#/$defs/effective_dates" },
        "timeframe_type": { "type": "string" },
        "timeframe_num": { "type": "number" },
        "pain_timeframes": { "$ref": "#/$defs/pain_timeframes" },
        "artifacts": { "$ref": "#/$defs/artifacts" },
        "note": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        }
      },
      "additionalProperties": false
    },
    "pain_timeframes": {
      "type": "object",
      "required": ["1", "2", "3", "4", "5"],
      "properties": {
        "1": { "$ref": "#/$defs/pain_timeframe_group" },
        "2": { "$ref": "#/$defs/pain_timeframe_group" },
        "3": { "$ref": "#/$defs/pain_timeframe_group" },
        "4": { "$ref": "#/$defs/pain_timeframe_group" },
        "5": { "$ref": "#/$defs/pain_timeframe_group" }
      },
      "propertyNames": { "pattern": "^[1-5]$" },
      "additionalProperties": { "$ref": "#/$defs/pain_timeframe_group" }
    },
    "pain_timeframe_group": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/pain_timeframe_entry" }
    },
    "pain_timeframe_entry": {
      "type": "object",
      "required": ["timeframe_type", "timeframe_num", "description"],
      "properties": {
        "timeframe_type": { "type": "string" },
        "timeframe_num": { "type": "number" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ksi_indicator": {
      "type": "object",
      "required": ["name", "controls", "updated"],
      "oneOf": [
        {
          "properties": { "statement": {} },
          "required": ["statement"],
          "not": {
            "properties": { "varies_by_class": {} },
            "required": ["varies_by_class"]
          }
        },
        {
          "properties": { "varies_by_class": {} },
          "required": ["varies_by_class"],
          "not": {
            "anyOf": [
              {
                "properties": { "statement": {} },
                "required": ["statement"]
              }
            ]
          }
        }
      ],
      "properties": {
        "name": { "type": "string" },
        "statement": { "type": "string" },
        "controls": { "type": "array", "items": { "type": "string" } },
        "reference": { "type": "string" },
        "reference_url": { "type": "string", "format": "uri" },
        "updated": { "$ref": "#/$defs/updated_list" },
        "artifacts": { "$ref": "#/$defs/artifacts" },
        "varies_by_class": {
          "type": "object",
          "required": ["b", "c"],
          "properties": {
            "a": { "$ref": "#/$defs/ksi_indicator_level" },
            "b": { "$ref": "#/$defs/ksi_indicator_level" },
            "c": { "$ref": "#/$defs/ksi_indicator_level" },
            "d": { "$ref": "#/$defs/ksi_indicator_level" }
          },
          "additionalProperties": false
        },
        "terms": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "ksi_indicator_level": {
      "type": "object",
      "required": ["statement"],
      "properties": {
        "statement": { "type": "string" },
        "artifacts": { "$ref": "#/$defs/artifacts" }
      },
      "additionalProperties": false
    },
    "default_artifacts": {
      "type": "object",
      "required": ["FRR", "KSI"],
      "properties": {
        "FRR": { "$ref": "#/$defs/artifact_list" },
        "KSI": { "$ref": "#/$defs/artifact_list" }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "all": { "$ref": "#/$defs/artifact_list" },
        "20x": { "$ref": "#/$defs/artifact_list" },
        "rev5": { "$ref": "#/$defs/artifact_list" }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "artifact_list": {
      "type": "array",
      "items": { "type": "string" }
    },
    "primary_key_word_enum": {
      "type": "string",
      "description": "Defines the primary keyword for a requirement or indicator, indicating its strength.",
      "enum": ["MUST", "SHOULD", "MAY", "MUST NOT", "SHOULD NOT"]
    },
    "updated_list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "comment"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "comment": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
