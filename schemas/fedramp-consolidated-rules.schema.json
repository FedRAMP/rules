{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fedramp.gov/schema/documentation.json",
  "title": "FedRAMP Consolidated Rules Schema",
  "type": "object",
  "required": ["info", "FRD", "FRR", "KSI"],
  "properties": {
    "info": {
      "type": "object",
      "required": ["title", "description", "version", "last_updated"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "last_updated": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "FRD": {
      "type": "object",
      "required": ["info", "data"],
      "properties": {
        "info": { "$ref": "#/$defs/document_info" },
        "data": { "$ref": "#/$defs/data_container_frd" }
      },
      "additionalProperties": false
    },
    "FRR": {
      "type": "object",
      "patternProperties": {
        "^[A-Z]{3}$": {
          "type": "object",
          "required": ["info", "data"],
          "properties": {
            "info": { "$ref": "#/$defs/document_info" },
            "data": { "$ref": "#/$defs/data_container_frr" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "KSI": {
      "type": "object",
      "patternProperties": {
        "^[A-Z]{3}$": {
          "type": "object",
          "required": ["id", "name", "web_name", "short_name", "indicators"],
          "properties": {
            "id": { "type": "string", "pattern": "^KSI-[A-Z]{3}$" },
            "name": { "type": "string" },
            "web_name": { "type": "string" },
            "short_name": { "type": "string", "pattern": "^[A-Z]{3}$" },
            "indicators": {
              "type": "object",
              "patternProperties": {
                "^KSI-[A-Z]{3}-[A-Z0-9]{3}$": {
                  "$ref": "#/$defs/ksi_indicator"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "document_info": {
      "type": "object",
      "required": [
        "name",
        "short_name",
        "web_name",
        "effective",
        "front_matter"
      ],
      "properties": {
        "name": { "type": "string" },
        "short_name": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "web_name": { "type": "string" },
        "effective": {
          "type": "object",
          "required": ["20x", "rev5"],
          "properties": {
            "20x": { "$ref": "#/$defs/effective_entry" },
            "rev5": { "$ref": "#/$defs/effective_entry" }
          },
          "additionalProperties": false
        },
        "front_matter": { "$ref": "#/$defs/front_matter" },
        "labels": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/frr_info_label_name" },
          "additionalProperties": { "$ref": "#/$defs/frr_label_definition" }
        }
      },
      "additionalProperties": false
    },
    "frr_data_label_name": {
      "enum": [
        "FRP",
        "CSO",
        "CSX",
        "CSL",
        "IAS",
        "IAX",
        "IAL",
        "AGM",
        "ADP",
        "BST",
        "CAS",
        "ENH",
        "EVA",
        "OCR",
        "PRE",
        "QTR",
        "RPT",
        "RTR",
        "TFR",
        "TRC",
        "TRF",
        "UTC"
      ]
    },
    "frr_info_label_name": {
      "anyOf": [{ "$ref": "#/$defs/frr_data_label_name" }]
    },
    "frr_label_definition": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "effective_entry": {
      "type": "object",
      "required": ["is"],
      "properties": {
        "is": { "type": "string", "enum": ["required", "optional", "no"] },
        "current_status": { "type": "string" },
        "date": { "$ref": "#/$defs/effective_dates" },
        "class": { "$ref": "#/$defs/effective_classes" },
        "comments": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "signup_url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "effective_dates": {
      "type": "object",
      "required": ["obtain", "maintain"],
      "properties": {
        "obtain": { "type": "string", "format": "date" },
        "maintain": { "type": "string", "format": "date" },
        "grace_ends": { "type": "string", "format": "date" },
        "grace_by_assessment_months": { "type": "number" }
      },
      "oneOf": [
        {
          "required": ["grace_ends"],
          "properties": {
            "grace_ends": {}
          }
        },
        {
          "required": ["grace_by_assessment_months"],
          "properties": {
            "grace_by_assessment_months": {}
          }
        }
      ],
      "additionalProperties": false
    },
    "effective_classes": {
      "type": "object",
      "required": ["a", "b", "c", "d"],
      "properties": {
        "a": { "$ref": "#/$defs/effective_class_entry" },
        "b": { "$ref": "#/$defs/effective_class_entry" },
        "c": { "$ref": "#/$defs/effective_class_entry" },
        "d": { "$ref": "#/$defs/effective_class_entry" }
      },
      "additionalProperties": false
    },
    "effective_class_entry": {
      "type": "object",
      "required": ["applies_in_full"],
      "properties": {
        "applies_in_full": { "type": "boolean" },
        "applies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]{3}-[A-Z]{3}-[A-Z0-9]{3}$"
          }
        }
      },
      "oneOf": [
        {
          "properties": {
            "applies_in_full": { "const": true }
          }
        },
        {
          "required": ["applies"],
          "properties": {
            "applies_in_full": { "const": false },
            "applies": {
              "type": "array",
              "minItems": 1
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "front_matter": {
      "type": "object",
      "required": ["purpose"],
      "properties": {
        "authority": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["reference", "reference_url", "description"],
            "properties": {
              "description": { "type": "string" },
              "reference": { "type": "string" },
              "reference_url": { "type": "string", "format": "uri" },
              "delegation": { "type": "string" },
              "delegation_url": { "type": "string", "format": "uri" }
            },
            "additionalProperties": false
          }
        },
        "purpose": { "type": "string" }
      },
      "additionalProperties": false
    },
    "data_container_frd": {
      "type": "object",
      "required": ["both"],
      "properties": {
        "both": { "$ref": "#/$defs/frd_definitions_map" },
        "20x": { "$ref": "#/$defs/frd_definitions_map" },
        "rev5": { "$ref": "#/$defs/frd_definitions_map" }
      },
      "additionalProperties": false
    },
    "frd_definitions_map": {
      "type": "object",
      "patternProperties": {
        "^FRD-[A-Z]{3}$": { "$ref": "#/$defs/frd_definition" }
      },
      "additionalProperties": false
    },
    "frd_definition": {
      "type": "object",
      "required": ["term", "definition", "alts", "updated"],
      "properties": {
        "term": { "type": "string" },
        "definition": { "type": "string" },
        "note": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "alts": { "type": "array", "items": { "type": "string" } },
        "reference": { "type": "string" },
        "reference_url": { "type": "string", "format": "uri" },
        "referenceurl": { "type": "string", "format": "uri" },
        "updated": { "$ref": "#/$defs/updated_list" }
      },
      "additionalProperties": false
    },
    "data_container_frr": {
      "type": "object",
      "properties": {
        "both": { "$ref": "#/$defs/frr_requirements_map" },
        "20x": { "$ref": "#/$defs/frr_requirements_map" },
        "rev5": { "$ref": "#/$defs/frr_requirements_map" }
      },
      "additionalProperties": false
    },
    "frr_requirements_map": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/frr_data_label_name" },
      "additionalProperties": { "$ref": "#/$defs/frr_requirements_label_group" }
    },
    "frr_requirements_label_group": {
      "type": "object",
      "patternProperties": {
        "^[A-Z]{3}-[A-Z]{3}-[A-Z0-9]{3}$": {
          "$ref": "#/$defs/frr_requirement"
        }
      },
      "additionalProperties": false
    },
    "frr_requirement": {
      "type": "object",
      "required": ["name", "affects"],
      "oneOf": [
        {
          "properties": { "statement": {}, "primary_key_word": {} },
          "required": ["statement", "primary_key_word"]
        },
        {
          "properties": { "varies_by_class": {} },
          "required": ["varies_by_class"],
          "not": {
            "required": ["primary_key_word"]
          }
        }
      ],
      "properties": {
        "name": { "type": "string" },
        "statement": { "type": "string" },
        "varies_by_class": {
          "type": "object",
          "required": ["b", "c"],
          "properties": {
            "a": { "$ref": "#/$defs/frr_requirement_level" },
            "b": { "$ref": "#/$defs/frr_requirement_level" },
            "c": { "$ref": "#/$defs/frr_requirement_level" },
            "d": { "$ref": "#/$defs/frr_requirement_level" }
          },
          "additionalProperties": false
        },
        "following_information": {
          "type": "array",
          "items": { "type": "string" }
        },
        "following_information_bullets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "danger": { "type": "string" },
        "note": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "reference": { "type": "string" },
        "reference_url": { "type": "string", "format": "uri" },
        "reference_url_web_name": { "type": "string" },
        "effective_date": { "$ref": "#/$defs/effective_dates" },
        "corrective_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "primary_key_word": {
          "$ref": "#/$defs/primary_key_word_enum"
        },
        "affects": { "type": "array", "items": { "type": "string" } },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "key_tests", "examples"],
            "properties": {
              "id": { "type": "string" },
              "key_tests": { "type": "array", "items": { "type": "string" } },
              "examples": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "timeframe_type": { "type": "string" },
        "timeframe_num": { "type": "number" },
        "notification": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["party", "method", "target"],
            "properties": {
              "party": { "type": "string" },
              "method": { "type": "string" },
              "target": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "controls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "terms": { "type": "array", "items": { "type": "string" } },
        "updated": { "$ref": "#/$defs/updated_list" }
      },
      "additionalProperties": false
    },
    "frr_requirement_level": {
      "type": "object",
      "required": ["primary_key_word", "statement"],
      "properties": {
        "statement": { "type": "string" },
        "primary_key_word": { "$ref": "#/$defs/primary_key_word_enum" },
        "effective_date": { "$ref": "#/$defs/effective_dates" },
        "timeframe_type": { "type": "string" },
        "timeframe_num": { "type": "number" },
        "pain_timeframes": { "$ref": "#/$defs/pain_timeframes" }
      },
      "additionalProperties": false
    },
    "pain_timeframes": {
      "type": "object",
      "required": ["1", "2", "3", "4", "5"],
      "properties": {
        "1": { "$ref": "#/$defs/pain_timeframe_group" },
        "2": { "$ref": "#/$defs/pain_timeframe_group" },
        "3": { "$ref": "#/$defs/pain_timeframe_group" },
        "4": { "$ref": "#/$defs/pain_timeframe_group" },
        "5": { "$ref": "#/$defs/pain_timeframe_group" }
      },
      "propertyNames": { "pattern": "^[1-5]$" },
      "additionalProperties": { "$ref": "#/$defs/pain_timeframe_group" }
    },
    "pain_timeframe_group": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/pain_timeframe_entry" }
    },
    "pain_timeframe_entry": {
      "type": "object",
      "required": ["timeframe_type", "timeframe_num", "description"],
      "properties": {
        "timeframe_type": { "type": "string" },
        "timeframe_num": { "type": "number" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ksi_indicator": {
      "type": "object",
      "required": ["name", "controls", "updated"],
      "oneOf": [
        {
          "properties": { "statement": {} },
          "required": ["statement"]
        },
        {
          "properties": { "varies_by_class": {} },
          "required": ["varies_by_class"]
        }
      ],
      "properties": {
        "name": { "type": "string" },
        "statement": { "type": "string" },
        "controls": { "type": "array", "items": { "type": "string" } },
        "reference": { "type": "string" },
        "reference_url": { "type": "string", "format": "uri" },
        "updated": { "$ref": "#/$defs/updated_list" },
        "varies_by_class": {
          "type": "object",
          "required": ["b", "c"],
          "properties": {
            "a": { "$ref": "#/$defs/ksi_indicator_level" },
            "b": { "$ref": "#/$defs/ksi_indicator_level" },
            "c": { "$ref": "#/$defs/ksi_indicator_level" },
            "d": { "$ref": "#/$defs/ksi_indicator_level" }
          },
          "additionalProperties": false
        },
        "terms": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "ksi_indicator_level": {
      "type": "object",
      "required": ["statement"],
      "properties": {
        "statement": { "type": "string" }
      },
      "additionalProperties": false
    },
    "primary_key_word_enum": {
      "type": "string",
      "description": "Defines the primary keyword for a requirement or indicator, indicating its strength.",
      "enum": ["MUST", "SHOULD", "MAY", "MUST NOT", "SHOULD NOT"]
    },
    "updated_list": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "comment"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "comment": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
